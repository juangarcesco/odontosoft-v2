  @if (!cargando() && archivos().length === 0) {
    <p class="estado-info">Aún no se han generado archivos RIPS.</p>
  }

  @if (archivos().length > 0) {
    <table class="tabla-historial">
      <thead>
        <tr>
          <th>Periodo</th>
          <th>Atenciones incluidas</th>
          <th>Generado por</th>
          <th>Fecha de generación</th>
        </tr>
      </thead>
      <tbody>
        @for (a of archivos(); track a._id) {
          <tr>
            <td class="periodo">{{ formatearPeriodo(a.periodo) }}</td>
            <td>{{ a.cantidadAtenciones }}</td>
            <td>{{ nombreUsuario(a.generadoPor) }}</td>
            <td>{{ a.createdAt | date: 'medium' }}</td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>
</file>

