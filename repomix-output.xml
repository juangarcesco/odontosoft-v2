const jwt = require('jsonwebtoken');

function generarToken(usuario) {
  const payload = {
    id: usuario._id,
    rol: usuario.rol,
    nombre: usuario.nombre,
  };

  return jwt.sign(payload, process.env.JWT_SECRET, {
