<div class="contenedor">
  <div class="encabezado">
    <h1>Agenda</h1>
    <a routerLink="/citas/nueva" class="btn-primario">+ Nueva cita</a>
  </div>

  <div class="controles">
    <div class="selector-vista">
      <button [class.activo]="vista() === 'dia'" (click)="cambiarVista('dia')">Día</button>
      <button [class.activo]="vista() === 'semana'" (click)="cambiarVista('semana')">Semana</button>
      <button [class.activo]="vista() === 'mes'" (click)="cambiarVista('mes')">Mes</button>
    </div>

    <div class="navegacion">
      <button (click)="irAnterior()">← Anterior</button>
      <button (click)="irHoy()" class="btn-hoy">Hoy</button>
      <button (click)="irSiguiente()">Siguiente →</button>
    </div>
  </div>

  <h2 class="rango-actual">{{ rangoTexto() }}</h2>

  @if (cargando()) {
    <p class="estado-info">Cargando...</p>
  }

  @if (error()) {
    <p class="estado-error">{{ error() }}</p>
  }

  @if (!cargando() && citas().length === 0) {
    <p class="estado-info">No hay citas en este rango.</p>
  }

  @for (grupo of citasAgrupadasPorDia(); track grupo[0]) {
    <div class="dia-agenda">
      <h3>{{ formatearNombreDia(grupo[0]) }}</h3>
      <div class="lista-citas">
        @for (cita of grupo[1]; track cita._id) {
          <div class="tarjeta-cita" [class]="claseEstado(cita.estado)">
            <div class="info-cita">
              <span class="hora">{{ cita.hora }}</span>
              <span class="paciente">{{ nombrePaciente(cita) }}</span>
              <span class="motivo">{{ cita.motivo }}</span>
              <span class="odontologo">{{ nombreOdontologo(cita) }}</span>
            </div>

            <div class="acciones-cita">
              @if (puedeGestionar() && cita.estado !== 'CANCELADA') {
                <select
                  class="select-estado"
                  [value]="cita.estado"
                  [disabled]="actualizandoEstadoId() === cita._id"
                  (change)="onCambiarEstado(cita._id, $any($event.target).value)"
                >
                  @for (estado of estadosDisponibles; track estado) {
                    <option [value]="estado">{{ estado }}</option>
                  }
                </select>
              } @else {
                <span class="badge-estado">{{ cita.estado }}</span>
              }

              @if (puedeEditarOCancelar()) {
                <a [routerLink]="['/citas', cita._id, 'editar']" class="link-editar">Editar</a>
                @if (cita.estado !== 'CANCELADA') {
                  <button
                    type="button"
                    class="btn-cancelar"
                    [disabled]="actualizandoEstadoId() === cita._id"
                    (click)="cancelarCita(cita._id)"
                  >
                    Cancelar
                  </button>
                }
              }
            </div>
          </div>
        }
      </div>
    </div>
  }
</div>
