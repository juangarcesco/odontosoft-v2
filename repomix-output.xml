      match: [/^([01]\d|2[0-3]):([0-5]\d)$/, 'La hora debe tener formato HH:mm'],
    },
    duracion: {
      type: Number, // minutos
      enum: [30, 45, 60],
      default: 30,
      required: [true, 'La duración es obligatoria'],
    },
    motivo: {
      type: String,
      trim: true,
      required: [true, 'El motivo de la cita es obligatorio'],
    },
