    },
    creadoPor: {
      type: mongoose.Schema.Types.ObjectId,
      ref: 'Usuario',
    },
  },
  { timestamps: true }
);

// RF-16: no se puede repetir el mismo número + tipo de documento (RN-02)
pacienteSchema.index({ tipoDocumento: 1, numeroDocumento: 1 }, { unique: true });

