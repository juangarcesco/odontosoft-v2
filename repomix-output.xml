    },
    email: {
      type: String,
      trim: true,
      lowercase: true,
      match: [/^\S+@\S+\.\S+$/, 'El email no tiene un formato válido'],
    },
    direccion: {
      type: String,
      trim: true,
    },
    ciudad: {
      type: String,
      trim: true,
    },
    eps: {
      type: String,
      trim: true,
    },
    grupoSanguineo: {
      type: String,
      enum: ['O+', 'O-', 'A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'NO_REGISTRA'],
      default: 'NO_REGISTRA',
    },
    alergias: {
      type: String,
      trim: true,
      default: '',
    },
    observaciones: {
      type: String,
      trim: true,
      default: '',
    },
    estado: {
      type: String,
      enum: ['ACTIVO', 'INACTIVO'],
