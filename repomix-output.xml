    <div class="paginador">
      <button [disabled]="pag.pagina <= 1" (click)="irAPagina(pag.pagina - 1)">← Anterior</button>
      <span>Página {{ pag.pagina }} de {{ pag.totalPaginas }} ({{ pag.total }} pacientes)</span>
      <button [disabled]="pag.pagina >= pag.totalPaginas" (click)="irAPagina(pag.pagina + 1)">Siguiente →</button>
    </div>
  }
</div>
